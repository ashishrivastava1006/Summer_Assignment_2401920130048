3.#include <iostream>
using namespace std;

class Point {
private:
    int x, y;

public:
    Point() {
        x = 0;
        y = 0;
    }

    Point(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void setX(int x) {
        this->x = x;
    }

    void setY(int y) {
        this->y = y;
    }

    void setXY(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void display() {
        cout << "(" << x << ", " << y << ")" << endl;
    }
};

int main() {
    Point p1;
    Point p2(5, 10);

    p1.display();
    p2.display();

    p1.setX(7);
    p1.setY(8);
    p1.display();

    p2.setXY(20, 30);
    p2.display();

    return 0;
}
4.#include <iostream>
using namespace std;

class Box {
protected:
    double length, breadth;

public:
    Box(double l, double b) {
        length = l;
        breadth = b;
    }

    double area() {
        return length * breadth;
    }
};

class Box3D : public Box {
private:
    double height;

public:
    Box3D(double l, double b, double h) : Box(l, b) {
        height = h;
    }

    double volume() {
        return length * breadth * height;
    }
};

int main() {
    double l, b, h;

    cout << "Enter Length Breadth Height: ";
    cin >> l >> b >> h;

    Box box(l, b);
    Box3D box3d(l, b, h);

    cout << "Area = " << box.area() << endl;
    cout << "Volume = " << box3d.volume() << endl;

    return 0;
}
